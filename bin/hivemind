#!/usr/bin/env bash
# hivemind — HiveMind thin CLI.
#
# Analogous to silken-runtime but standalone — zero lab deps.
# Runs in the user's project directory; slug = explicit arg or interactive
# picker (fail-closed if non-interactive — no basename(cwd) fallback).
#
# Usage:
#   hivemind [<slug>]     # start proxy + exec claude; slug = arg or interactive picker
#   hivemind start        # start proxy only (no claude)
#   hivemind stop         # stop the proxy
#   hivemind restart      # stop + start (best-effort; re-reads ~/.hivemind/.env)
#   hivemind status       # proxy health + cert validity (human-readable)
#   hivemind health       # same checks as status, script-friendly exit code (0/1/2)
#   hivemind update       # pull-agent: staged+verified+atomic update, auto-rollback
#   hivemind --version    # print version and exit
#   hivemind --verbose [...]  # show startup/debug logs (default: quiet, GO/NO-GO only)

set -euo pipefail

HIVEMIND_VERSION="0.1.0"
HIVEMIND_HOME="${HIVEMIND_HOME:-$HOME/.hivemind}"
RUNTIME_PORT="${AR_PORT:-7777}"
PROXY_PORT="${MTLS_PROXY_PORT:-7779}"
# Product state lives under ~/.engram — a dedicated, hidden dir, fully
# isolated from the lab's own ~/.fos (which the lab's own agent-runtime/CLI
# uses). Zero shared footprint: a machine with both the lab and this product
# installed must never collide on cert material or cache/pid files.
RUNTIME_LOG="${HOME}/.engram/cache/hivemind-runtime.log"
RUNTIME_PID_FILE="${HOME}/.engram/cache/hivemind-runtime.pid"
# Leftover-session pidfile from an interrupted --setup-only run (see _setup_mode
# / cmd_stop hardening, item 4.2) — best-effort cleanup, not fatal if absent.
SETUP_PID_FILE="${HOME}/.engram/cache/hivemind-setup.pid"
CERT_DIR="${HOME}/.engram/mtls"
RUNTIME_BIN="${HIVEMIND_HOME}/runtime/src/server.ts"

# Load user env if present (sets MTLS_* + HIVEMIND_OWNER).
if [ -f "${HIVEMIND_HOME}/.env" ]; then
  # shellcheck disable=SC1090
  set -a; . "${HIVEMIND_HOME}/.env"; set +a
fi

# Refresh port vars after env load (env may override AR_PORT / MTLS_PROXY_PORT).
RUNTIME_PORT="${AR_PORT:-${RUNTIME_PORT}}"
PROXY_PORT="${MTLS_PROXY_PORT:-${PROXY_PORT}}"

# ── ANSI helpers (NO_COLOR-aware) ────────────────────────────────────────────
if [ -t 1 ] && [ -z "${NO_COLOR:-}" ]; then
  _ok()  { printf '\033[0;32m%s\033[0m' "$*"; }
  _err() { printf '\033[0;31m%s\033[0m' "$*"; }
  _dim() { printf '\033[2m%s\033[0m' "$*"; }
else
  _ok()  { printf '%s' "$*"; }
  _err() { printf '%s' "$*"; }
  _dim() { printf '%s' "$*"; }
fi

# ── _vecho: verbose-only stderr echo — gated behind --verbose (parsed at the
# entry point, bottom of file). Debug/startup noise lives behind this; GO/NO-GO
# status and errors stay unconditional.
_vecho() {
  [ "${_VERBOSE:-0}" = "1" ] && echo "$@" >&2
  return 0
}

# ── _brand_header: quiet-by-default output still shows this once ───────────
# F6.1 — minimal ASCII identity block: small, simple geometry (a single glyph
# + two lines), NOT a logo/illustration — studio is out of scope here (glyph
# is a placeholder for studio to revise later). Shows the resolved endpoint
# (HIVEMIND_ENDPOINT, defaulting to the product's own domain) so a lab<->
# product swap via .env is visible at every startup, not just in the .env file.
_brand_header() {
  echo ""
  echo "  $(_ok "◆") HiveMind — shared memory runtime"
  echo "  $(_dim "→ ${HIVEMIND_ENDPOINT:-hivemind.silken.ia.br:4443}")"
}

# ── _has_cert: returns 0 only if THIS owner's cert exists (owner-scoped) ─────
# Aligned with _check_health / cmd_status (:301+), which validate exactly
# "${CERT_DIR}/${HIVEMIND_OWNER}.cert.pem". A bare `ls *.cert.pem` glob (the
# previous impl) accepted a cert belonging to ANY owner — so a machine that
# already enrolled owner A would silently SKIP setup for owner B, then present
# owner B a runtime authenticated as A. Owner-scoped here closes that: another
# owner's cert present + this owner's cert absent → _has_cert fails → _setup_mode.
# The glob is kept ONLY as the fallback for when HIVEMIND_OWNER is unset (no
# owner to scope to yet — e.g. a partial/legacy .env), preserving prior
# behavior in that one degenerate case.
_has_cert() {
  [ -d "${CERT_DIR}" ] || return 1
  local _owner="${HIVEMIND_OWNER:-}"
  if [ -n "${_owner}" ]; then
    [ -f "${CERT_DIR}/${_owner}.cert.pem" ]
  else
    ls "${CERT_DIR}"/*.cert.pem > /dev/null 2>&1
  fi
}

# ── _check_health: single source of truth for runtime/proxy/cert/endpoint
# state — populates _HEALTH_* globals + _HEALTH_SEVERITY (0=ok, 1=degraded,
# 2=down). Never returns non-zero itself (severity lives in the variable, not
# in $?) — safe to call as a bare statement under `set -e`. Shared by
# cmd_status (human-readable) and cmd_health (script-friendly exit code).
_check_health() {
  _HEALTH_RUNTIME_OK=0
  _HEALTH_PROXY_CONFIGURED=0
  _HEALTH_PROXY_OK=0
  _HEALTH_CERT_STATE="absent"   # absent | valid | invalid | unknown
  _HEALTH_ENDPOINT_OK=0
  _HEALTH_SEVERITY=0

  if curl -sf "http://127.0.0.1:${RUNTIME_PORT}/healthz" > /dev/null 2>&1; then
    _HEALTH_RUNTIME_OK=1
  fi

  # Proxy is only counted against health if it's actually configured — dev
  # setups without MTLS_PROXY_PORT are a deliberate mode, not a failure.
  if [ -n "${MTLS_PROXY_PORT:-}" ]; then
    _HEALTH_PROXY_CONFIGURED=1
    if curl -sf "http://127.0.0.1:${PROXY_PORT}/v1/mcp" > /dev/null 2>&1; then
      _HEALTH_PROXY_OK=1
    fi
  fi

  local _owner="${HIVEMIND_OWNER:-}"
  if _has_cert; then
    if [ -n "${_owner}" ] && [ -f "${CERT_DIR}/${_owner}.cert.pem" ] && [ -f "${CERT_DIR}/ca.cert.pem" ]; then
      if openssl verify -CAfile "${CERT_DIR}/ca.cert.pem" \
           "${CERT_DIR}/${_owner}.cert.pem" > /dev/null 2>&1; then
        _HEALTH_CERT_STATE="valid"
      else
        _HEALTH_CERT_STATE="invalid"
      fi
    else
      _HEALTH_CERT_STATE="unknown"
    fi
  fi

  # Endpoint reachability — new check (item 4.3), public path, no cert needed.
  if curl -sf --max-time 3 "https://${HIVEMIND_ENDPOINT:-hivemind.silken.ia.br:4443}/ca/crl.pem" > /dev/null 2>&1; then
    _HEALTH_ENDPOINT_OK=1
  fi

  if [ "${_HEALTH_RUNTIME_OK}" -eq 0 ]; then
    _HEALTH_SEVERITY=2
  elif { [ "${_HEALTH_PROXY_CONFIGURED}" -eq 1 ] && [ "${_HEALTH_PROXY_OK}" -eq 0 ]; } \
    || [ "${_HEALTH_CERT_STATE}" = "invalid" ] \
    || [ "${_HEALTH_ENDPOINT_OK}" -eq 0 ]; then
    _HEALTH_SEVERITY=1
  fi
  return 0
}

# ── _pid_is_hivemind_runtime: guards cmd_stop against killing a PID the OS
# recycled for an unrelated process after a crash left a stale pidfile behind.
# Matches the FULL absolute RUNTIME_BIN path (fixed-string, not a loose
# 'server.ts' fragment) — a generic 'server.ts' substring would false-positive
# on an unrelated `vim server.ts` or `tail -f server.ts.log` sharing the
# recycled PID, which is exactly the failure this guard exists to prevent.
_pid_is_hivemind_runtime() {
  local _pid="$1"
  ps -p "${_pid}" -o command= 2>/dev/null | grep -qF -- "${RUNTIME_BIN}"
}

# ── _setup_mode: first-login flow ─────────────────────────────────────────────
# Starts server in setup-only mode, opens browser, polls /setup/status until done.
_setup_mode() {
  _brand_header
  echo "First run detected — no certificate found."
  echo "Starting setup server..."

  if ! command -v bun > /dev/null 2>&1; then
    echo "Error: 'bun' is required but not found." >&2
    echo "Install bun: curl -fsSL https://bun.sh/install | bash" >&2
    exit 1
  fi
  if ! command -v openssl > /dev/null 2>&1; then
    echo "Error: 'openssl' is required but not found." >&2
    exit 1
  fi
  if [ ! -f "${RUNTIME_BIN}" ]; then
    echo "Error: runtime not found at ${RUNTIME_BIN}" >&2
    echo "Re-run: bash install.sh" >&2
    exit 1
  fi

  mkdir -p "$(dirname "${RUNTIME_LOG}")"
  bun run "${RUNTIME_BIN}" --setup-only >> "${RUNTIME_LOG}" 2>&1 &
  _SETUP_PID=$!
  mkdir -p "$(dirname "${SETUP_PID_FILE}")"
  echo "${_SETUP_PID}" > "${SETUP_PID_FILE}"

  # Poll until setup server ready (timeout 15s).
  _TRIES=0
  until curl -sf "http://127.0.0.1:${RUNTIME_PORT}/healthz" > /dev/null 2>&1; do
    _TRIES=$((_TRIES + 1))
    if [ "${_TRIES}" -ge 15 ]; then
      echo "Error: setup server did not start after 15s. Check: ${RUNTIME_LOG}" >&2
      kill "${_SETUP_PID}" 2>/dev/null || true
      rm -f "${SETUP_PID_FILE}"
      exit 1
    fi
    sleep 1
  done

  local _SETUP_URL="http://localhost:${RUNTIME_PORT}/setup"
  echo "Opening browser: ${_SETUP_URL}"

  if command -v xdg-open > /dev/null 2>&1; then
    xdg-open "${_SETUP_URL}" > /dev/null 2>&1 &
  elif command -v open > /dev/null 2>&1; then
    open "${_SETUP_URL}" &
  else
    echo "(Could not auto-open browser — open manually: ${_SETUP_URL})"
  fi

  echo "Fill in your Enrollment Token and Owner ID, then click 'Configure mTLS'."
  echo "Waiting for enrollment to complete (timeout: 5 min)..."

  # Poll /setup/status until done (timeout 300s / 5 min).
  # NOTE: `grep -q` used directly as the if-condition — a prior version used
  # `grep -c ... || echo 0` into a variable, but grep -c exits 1 when the
  # count is 0 (even though it prints "0"), which under pipefail ALSO fires
  # the `|| echo 0` fallback, producing a duplicated "0\n0" that broke the
  # `-gt` integer test every tick. grep -q as a bare condition has no such
  # count-vs-exit-code mismatch to trip over.
  _TRIES=0
  while :; do
    if curl -sf "http://127.0.0.1:${RUNTIME_PORT}/setup/status" 2>/dev/null \
      | grep -q '"done":true'; then
      break
    fi
    _TRIES=$((_TRIES + 1))
    if [ "${_TRIES}" -ge 300 ]; then
      echo "Timeout: enrollment did not complete in 5 minutes." >&2
      kill "${_SETUP_PID}" 2>/dev/null || true
      rm -f "${SETUP_PID_FILE}"
      exit 1
    fi
    sleep 1
  done

  kill "${_SETUP_PID}" 2>/dev/null || true
  rm -f "${SETUP_PID_FILE}"
  echo ""
  echo "Done. Run 'hivemind' in your project directory to start."
  exit 0
}

# ── _start_proxy: ensure the runtime+proxy is running ─────────────────────────
_start_proxy() {
  if curl -sf "http://127.0.0.1:${RUNTIME_PORT}/healthz" > /dev/null 2>&1; then
    return 0
  fi

  if ! command -v bun > /dev/null 2>&1; then
    echo "Error: 'bun' is required. Install: curl -fsSL https://bun.sh/install | bash" >&2
    exit 1
  fi
  if [ ! -f "${RUNTIME_BIN}" ]; then
    echo "Error: runtime not found at ${RUNTIME_BIN}. Re-run: bash install.sh" >&2
    exit 1
  fi

  mkdir -p "$(dirname "${RUNTIME_LOG}")"
  bun run "${RUNTIME_BIN}" >> "${RUNTIME_LOG}" 2>&1 &
  echo $! > "${RUNTIME_PID_FILE}"

  _vecho "[hivemind] starting runtime..."
  _TRIES=0
  until curl -sf "http://127.0.0.1:${RUNTIME_PORT}/healthz" > /dev/null 2>&1; do
    _TRIES=$((_TRIES + 1))
    if [ "${_TRIES}" -ge 15 ]; then
      echo "Error: hivemind runtime did not start after 15s. Check: ${RUNTIME_LOG}" >&2
      exit 1
    fi
    sleep 1
  done
  _vecho "[hivemind] runtime up (pid=$(cat "${RUNTIME_PID_FILE}" 2>/dev/null || echo '?'))"
}

# ── Subcommands ───────────────────────────────────────────────────────────────

cmd_version() {
  echo "HiveMind v${HIVEMIND_VERSION}"
}

cmd_help() {
  echo "Usage: hivemind [<slug>] | start | stop | restart | status | health | update | --version"
  echo ""
  echo "  hivemind [<slug>]   Start proxy + open Claude Code (slug = arg, else interactive picker)"
  echo "  hivemind start      Start proxy only"
  echo "  hivemind stop       Stop the proxy"
  echo "  hivemind restart    Stop + start (best-effort)"
  echo "  hivemind status     Show proxy health and certificate validity (human-readable)"
  echo "  hivemind health     Same checks as status; exit 0=ok 1=degraded 2=down"
  echo "  hivemind update     Pull-agent: staged + verified + atomic update, auto-rollback"
  echo "  hivemind --version  Print version"
  echo ""
  echo "  --verbose           Show startup/debug logs (default: quiet, GO/NO-GO + errors only)"
}

cmd_status() {
  _check_health
  echo "HiveMind v${HIVEMIND_VERSION} — status"
  echo ""

  if [ "${_HEALTH_RUNTIME_OK}" = "1" ]; then
    echo "  Runtime:    $(_ok "OK") (port ${RUNTIME_PORT})"
  else
    echo "  Runtime:    $(_err "STOPPED") (port ${RUNTIME_PORT})"
  fi

  if [ "${_HEALTH_PROXY_CONFIGURED}" = "1" ]; then
    if [ "${_HEALTH_PROXY_OK}" = "1" ]; then
      echo "  mTLS proxy: $(_ok "OK") (port ${PROXY_PORT})"
    else
      echo "  mTLS proxy: $(_err "not responding") (port ${PROXY_PORT})"
    fi
  else
    echo "  mTLS proxy: $(_dim "not configured") (port ${PROXY_PORT})"
  fi

  local _owner="${HIVEMIND_OWNER:-}"
  case "${_HEALTH_CERT_STATE}" in
    valid)   echo "  Cert:       $(_ok "VALID") (owner=${_owner})" ;;
    invalid) echo "  Cert:       $(_err "INVALID") — re-enroll: rm -rf ${CERT_DIR} && hivemind" ;;
    unknown) echo "  Cert:       $(_dim "present (run 'hivemind' to validate)")" ;;
    *)       echo "  Cert:       $(_dim "NOT FOUND") — run 'hivemind' to enroll" ;;
  esac

  if [ "${_HEALTH_ENDPOINT_OK}" = "1" ]; then
    echo "  Endpoint:   $(_ok "reachable") (${HIVEMIND_ENDPOINT:-hivemind.silken.ia.br:4443})"
  else
    echo "  Endpoint:   $(_dim "unreachable") (${HIVEMIND_ENDPOINT:-hivemind.silken.ia.br:4443})"
  fi
}

cmd_health() {
  _check_health
  case "${_HEALTH_SEVERITY}" in
    0) echo "$(_ok "OK") — runtime, proxy, cert and endpoint healthy" ;;
    1) echo "$(_err "DEGRADED") — run 'hivemind status' for details" ;;
    2) echo "$(_err "DOWN") — runtime not responding on port ${RUNTIME_PORT}" ;;
  esac
  return "${_HEALTH_SEVERITY}"
}

cmd_start() {
  if ! _has_cert; then _setup_mode; fi
  _start_proxy
  echo "[hivemind] proxy running on port ${PROXY_PORT}"
}

cmd_stop() {
  if [ -f "${RUNTIME_PID_FILE}" ]; then
    local _pid
    _pid=$(cat "${RUNTIME_PID_FILE}" 2>/dev/null || echo '')
    if [ -n "${_pid}" ] && kill -0 "${_pid}" 2>/dev/null; then
      if _pid_is_hivemind_runtime "${_pid}"; then
        kill "${_pid}"
        rm -f "${RUNTIME_PID_FILE}"
        echo "[hivemind] runtime stopped"
      else
        # Stale pidfile: PID is alive but recycled by the OS for an unrelated
        # process (crash left the pidfile behind) — do NOT kill it.
        echo "[hivemind] pidfile PID ${_pid} is not a hivemind runtime (stale/recycled) — not killing, clearing pidfile" >&2
        rm -f "${RUNTIME_PID_FILE}"
      fi
    else
      echo "[hivemind] no running runtime at pid ${_pid}"
      rm -f "${RUNTIME_PID_FILE}"
    fi
  else
    echo "[hivemind] no runtime pid file found (already stopped?)"
  fi

  # Best-effort cleanup of a leftover --setup-only session (e.g. hivemind was
  # interrupted mid-enrollment and the background setup server never exited).
  if [ -f "${SETUP_PID_FILE}" ]; then
    local _setup_pid
    _setup_pid=$(cat "${SETUP_PID_FILE}" 2>/dev/null || echo '')
    if [ -n "${_setup_pid}" ] && kill -0 "${_setup_pid}" 2>/dev/null; then
      kill "${_setup_pid}" 2>/dev/null || true
    fi
    rm -f "${SETUP_PID_FILE}"
  fi
}

cmd_restart() {
  cmd_stop
  _start_proxy
  echo "[hivemind] restarted"
}

# ── Update mechanism (item 4.4) ───────────────────────────────────────────────
# Pull-agent for the thin client: bin/hivemind + runtime/src/* ONLY — prompts/
# seeds are never touched here (they live server-side since the Fase 1 stub).
# Hardened per OPEN-6 (silent auto-pull): pinned source, integrity check,
# staged+atomic swap, last-known-good rollback. See docs/wip plan, item 13.

# _verify_commit_integrity: 0 = trusted, 1 = refuse to apply.
# Two paths, either sufficient: (a) valid GPG signature via `git verify-commit`
# from a signer git already trusts; (b) commit hash matches a LATEST_SHA
# manifest published on a channel separate from git itself (the product HTTPS
# domain, not the repo host) — fallback for when no signer is configured.
# HONEST GAP: the manifest endpoint (https://<host>/hivemind/LATEST_SHA) does
# not exist server-side yet (not part of this slice's scope) — until it's
# stood up, this fails closed for unsigned commits, which is the correct
# fail-safe default (spec: "se a verificação falhar → NÃO aplica"), not a bug.
_verify_commit_integrity() {
  local _dir="$1"
  if git -C "${_dir}" verify-commit HEAD > /dev/null 2>&1; then
    return 0
  fi
  local _host="${HIVEMIND_ENDPOINT%%:*}"
  local _manifest_url="https://${_host}/hivemind/LATEST_SHA"
  local _expected_sha
  _expected_sha="$(curl -sf --max-time 5 "${_manifest_url}" 2>/dev/null | tr -d '[:space:]')"
  [ -n "${_expected_sha}" ] || return 1
  local _actual_sha
  _actual_sha="$(git -C "${_dir}" rev-parse HEAD)"
  [ "${_actual_sha}" = "${_expected_sha}" ]
}

# _stage_build: mirrors install.sh's $HIVEMIND_HOME-scoped copy step (CLAUDE.md,
# .claude/settings.json, runtime/ + bun install) into a STAGING dir — never
# touches the live $HIVEMIND_HOME. Deliberately does NOT reinstall the CLI
# binary to PATH (that's handled separately, see _update_installed_binary) and
# does NOT run install.sh's dependency/PATH checks or smoke test (those are
# first-install concerns, not update concerns).
#
# Two-tier copy (code-review fix, post-5.1/5.2/5.3 — replaces a cherry-pick
# allowlist that was a BLOCKER): (1) GIT-MANAGED paths — CLAUDE.md, settings.json,
# commands/, runtime/ — the NEW version from HIVEMIND_SOURCE_DIR always wins;
# (2) RUNTIME-WRITTEN state — everything Claude Code / the enrollment flow
# writes into $HIVEMIND_HOME at runtime (NOT sourced from git: .env,
# .claude/.claude.json [mcpServers.engram, item 5.1], .claude/.credentials.json
# [item 5.0], plus whatever Claude Code writes next — history.jsonl, sessions/,
# projects/, shell-snapshots/, caches, none of it enumerable up front) — the
# LIVE state always wins. A fixed allowlist (the previous version of this
# function only preserved .env + .credentials.json) silently drops every other
# runtime-written file on the first 'hivemind update' — this is exactly what
# broke the item 5.1 MCP fix (.claude.json is written by the ENROLLMENT
# handler at runtime, not by git, so it was never in the allowlist and got
# wiped by the staging mv). Inverting the pattern to "preserve everything,
# except what git explicitly owns" closes that class of regression instead of
# cherry-picking the next file that turns out to matter.
_stage_build() {
  local _target="$1"
  mkdir -p "${_target}/.claude" "${_target}/.claude/hooks" "${_target}/bin" "${_target}/runtime" || return 1

  # ── Tier 1: git-managed — NEW version wins ────────────────────────────────
  # CLAUDE.md lands under .claude/ — mirrors install.sh's item 5.2 fix
  # (load-bearing: forgetting this side regresses the pull-agent silently).
  cp "${HIVEMIND_SOURCE_DIR}/CLAUDE.md" "${_target}/.claude/CLAUDE.md" || return 1
  # settings.json is TEMPLATED (F5.3), same as install.sh — __HIVEMIND_HOME__
  # resolves against the LIVE HIVEMIND_HOME (this update targets the same
  # install, not a fresh one), not the staging dir itself.
  sed "s|__HIVEMIND_HOME__|${HIVEMIND_HOME}|g" \
    "${HIVEMIND_SOURCE_DIR}/.claude/settings.json" > "${_target}/.claude/settings.json" || return 1
  # Product slash-commands (item 5.3) — same mirror requirement as above.
  mkdir -p "${_target}/.claude/commands" || return 1
  cp -r "${HIVEMIND_SOURCE_DIR}/.claude/commands/." "${_target}/.claude/commands/" || return 1
  # Status-CLI (F5.1) + quota-capture hook (F5.2) — referenced by the
  # templated settings.json above; must ship alongside it on every update.
  cp "${HIVEMIND_SOURCE_DIR}/bin/hivemind-statusline.py" "${_target}/bin/hivemind-statusline.py" || return 1
  chmod +x "${_target}/bin/hivemind-statusline.py" || return 1
  cp "${HIVEMIND_SOURCE_DIR}/.claude/hooks/user-prompt-submit.capture-quota.js" \
    "${_target}/.claude/hooks/user-prompt-submit.capture-quota.js" || return 1
  rsync -a --exclude='node_modules/' --exclude='bun.lock' \
    "${HIVEMIND_SOURCE_DIR}/runtime/" "${_target}/runtime/" 2>/dev/null \
    || cp -r "${HIVEMIND_SOURCE_DIR}/runtime/." "${_target}/runtime/" || return 1
  (cd "${_target}/runtime" && bun install --silent 2>/dev/null || bun install) || return 1

  # ── Tier 2: runtime-written — LIVE state wins ─────────────────────────────
  # Preserve the LIVE .env (cert paths, endpoint, update pinning) — the staged
  # build must boot with the same identity/config as the current one, not a
  # fresh/empty one.
  if [ -f "${HIVEMIND_HOME}/.env" ]; then
    cp "${HIVEMIND_HOME}/.env" "${_target}/.env" || return 1
  fi
  # Merge the ENTIRE live .claude/ dir over the staged one, EXCLUDING exactly
  # the 4 git-managed paths already placed above (anchored to the transfer
  # root with a leading '/' so a same-named file/dir nested deeper — e.g. under
  # sessions/ or projects/ — is never accidentally excluded). No --delete: this
  # only ADDS/overwrites from live into staging, it never removes a
  # freshly-placed git file. Covers .claude.json (item 5.1) + .credentials.json
  # (item 5.0) + anything else Claude Code writes there, present or future.
  # /hooks/ added at F5.2 (quota-capture hook is git-managed like
  # CLAUDE.md/settings.json/commands/, not runtime-written).
  if [ -d "${HIVEMIND_HOME}/.claude" ]; then
    rsync -a \
      --exclude='/CLAUDE.md' \
      --exclude='/settings.json' \
      --exclude='/commands/' \
      --exclude='/hooks/' \
      "${HIVEMIND_HOME}/.claude/" "${_target}/.claude/" || return 1
  fi
  return 0
}

# _update_installed_binary / _rollback_installed_binary: the system-PATH copy
# of bin/hivemind is outside $HIVEMIND_HOME, so it needs its own (small,
# already-atomic) swap — cp-to-temp + rename, mirroring the staging pattern at
# a smaller scale. Best-effort: if the installed path isn't writable, skip
# (not fatal — the $HIVEMIND_HOME swap is the load-bearing part).
_update_installed_binary() {
  local _installed_bin
  _installed_bin="$(command -v hivemind 2>/dev/null || true)"
  [ -n "${_installed_bin}" ] && [ -w "${_installed_bin}" ] || return 0
  cp "${_installed_bin}" "${_installed_bin}.last-good" 2>/dev/null || true
  cp "${HIVEMIND_SOURCE_DIR}/bin/hivemind" "${_installed_bin}.new" || return 1
  chmod +x "${_installed_bin}.new"
  mv "${_installed_bin}.new" "${_installed_bin}"
}
_rollback_installed_binary() {
  local _installed_bin
  _installed_bin="$(command -v hivemind 2>/dev/null || true)"
  if [ -n "${_installed_bin}" ] && [ -f "${_installed_bin}.last-good" ]; then
    mv "${_installed_bin}.last-good" "${_installed_bin}"
  fi
}

cmd_update() {
  if [ -z "${HIVEMIND_SOURCE_DIR:-}" ] || [ ! -d "${HIVEMIND_SOURCE_DIR}/.git" ]; then
    echo "Error: HIVEMIND_SOURCE_DIR not set or not a git clone — re-run install.sh to pin the update source." >&2
    exit 1
  fi

  local _branch="${HIVEMIND_UPDATE_BRANCH:-main}"

  # Source pinning guard (requirement 1): refuse if origin drifted from what
  # was recorded at install time — evicts a silent remote/DNS swap.
  local _current_remote
  _current_remote="$(git -C "${HIVEMIND_SOURCE_DIR}" remote get-url origin 2>/dev/null || echo '')"
  if [ -n "${HIVEMIND_UPDATE_REMOTE:-}" ] && [ "${_current_remote}" != "${HIVEMIND_UPDATE_REMOTE}" ]; then
    echo "Error: origin remote changed since install (pinned: ${HIVEMIND_UPDATE_REMOTE}, current: ${_current_remote}) — refusing to update." >&2
    exit 1
  fi

  echo "Checking ${_branch} for updates..."
  if ! git -C "${HIVEMIND_SOURCE_DIR}" fetch --quiet origin "${_branch}"; then
    echo "Error: fetch failed (network?) — staying on current version." >&2
    exit 1
  fi

  local _before _after
  _before="$(git -C "${HIVEMIND_SOURCE_DIR}" rev-parse HEAD)"
  _after="$(git -C "${HIVEMIND_SOURCE_DIR}" rev-parse "origin/${_branch}")"

  if [ "${_before}" = "${_after}" ]; then
    echo "Already up to date (${_before:0:12})."
    return 0
  fi

  if ! git -C "${HIVEMIND_SOURCE_DIR}" merge --ff-only "origin/${_branch}" > /dev/null 2>&1; then
    echo "Error: local clone diverged from ${_branch} (not fast-forward) — resolve manually." >&2
    exit 1
  fi

  # Requirement 2: integrity check. Fail-safe — on failure, revert the clone
  # to the pre-fetch commit and do NOT touch $HIVEMIND_HOME.
  if ! _verify_commit_integrity "${HIVEMIND_SOURCE_DIR}"; then
    echo "Error: integrity check FAILED for ${_after:0:12} — not applying, reverting clone to ${_before:0:12}." >&2
    git -C "${HIVEMIND_SOURCE_DIR}" reset --hard "${_before}" > /dev/null 2>&1 || true
    exit 1
  fi

  echo "Verified ${_after:0:12} — staging..."

  # Requirement 3: apply atomically via a staging dir + rename swap (never
  # copy-in-place onto the live $HIVEMIND_HOME).
  local _staging="${HIVEMIND_HOME}.staging"
  local _lastgood="${HIVEMIND_HOME}.last-good"
  rm -rf "${_staging}"

  if ! _stage_build "${_staging}"; then
    echo "Error: staging build failed — current installation untouched." >&2
    rm -rf "${_staging}"
    git -C "${HIVEMIND_SOURCE_DIR}" reset --hard "${_before}" > /dev/null 2>&1 || true
    exit 1
  fi

  echo "Staged — swapping in (atomic)..."
  cmd_stop > /dev/null 2>&1 || true
  rm -rf "${_lastgood}"
  # NOTE (deferred, not this pass — team-lead review): each `mv` below is
  # atomic on its own, but the two together are not a single atomic step —
  # there's a small window between them where $HIVEMIND_HOME doesn't exist at
  # all. Acceptable for now (auto-update is inert without a signer/manifest,
  # see _verify_commit_integrity); will be hardened alongside the signing
  # infra before update goes live. Manual recovery in the meantime: if a crash
  # lands here, restore from "${HIVEMIND_HOME}.last-good" (or re-run
  # install.sh from "${HIVEMIND_HOME}.staging" if last-good is also absent).
  if [ -d "${HIVEMIND_HOME}" ]; then
    mv "${HIVEMIND_HOME}" "${_lastgood}"
  fi
  mv "${_staging}" "${HIVEMIND_HOME}"
  # Best-effort: a failed binary swap here must NOT abort under set -e — the
  # $HIVEMIND_HOME swap already happened, and the health-check/rollback below
  # (requirement 4) still needs to run regardless of this side-swap's outcome.
  _update_installed_binary || true

  # Requirement 4: last-known-good + automatic rollback on a failed
  # post-update health check. _start_proxy exits(1) directly on its own
  # start-up failure (pre-existing behavior, relied on by cmd_start/cmd_open)
  # — run it in a SUBSHELL here so that exit only ends the subshell, not this
  # whole update, letting the rollback logic below actually run.
  ( _start_proxy ) || true
  _check_health

  if [ "${_HEALTH_SEVERITY}" -ge 2 ]; then
    echo "Error: post-update health check FAILED — rolling back to ${_before:0:12}." >&2
    cmd_stop > /dev/null 2>&1 || true
    rm -rf "${HIVEMIND_HOME}"
    mv "${_lastgood}" "${HIVEMIND_HOME}"
    git -C "${HIVEMIND_SOURCE_DIR}" reset --hard "${_before}" > /dev/null 2>&1 || true
    _rollback_installed_binary
    ( _start_proxy ) || true
    echo "Rolled back — running ${_before:0:12}." >&2
    exit 1
  fi

  echo "$(_ok "Updated"): ${_before:0:12} -> ${_after:0:12}."
}

# _maybe_auto_update: silent on-launch check (OPEN-6, founder-approved).
# Best-effort + fail-open on ANY network/config hiccup — never blocks startup.
# Short timeout (~2s) on the remote check only; the actual update (if one
# applies) reuses cmd_update's hardened staged/atomic/rollback path.
_maybe_auto_update() {
  [ -n "${HIVEMIND_SOURCE_DIR:-}" ] || return 0
  [ -d "${HIVEMIND_SOURCE_DIR}/.git" ] || return 0
  # BLOCKER FIX: `timeout` is not present on stock macOS (only via brew
  # coreutils). Without this guard, the `$(timeout ...)` command substitution
  # below fails with 127, and — being a variable assignment — set -e ABORTS
  # THE WHOLE SCRIPT right here, killing the default `hivemind`/`hivemind
  # <slug>` path before _start_proxy/exec claude ever run. Degrade instead:
  # no `timeout` → skip the silent auto-update, continue booting normally.
  command -v timeout > /dev/null 2>&1 || return 0

  local _branch="${HIVEMIND_UPDATE_BRANCH:-main}"
  local _remote_head
  _remote_head="$(timeout 2 git -C "${HIVEMIND_SOURCE_DIR}" ls-remote origin "refs/heads/${_branch}" 2>/dev/null | cut -f1)"
  [ -n "${_remote_head}" ] || return 0   # offline/timeout — fail-open, continue as-is

  local _local_head
  _local_head="$(git -C "${HIVEMIND_SOURCE_DIR}" rev-parse HEAD 2>/dev/null || echo '')"
  [ "${_remote_head}" != "${_local_head}" ] || return 0   # already current

  # cmd_update calls exit(1) directly on several failure paths — run it in a
  # SUBSHELL so a failed silent update can never take the whole launch down
  # with it (same reasoning as the _start_proxy wrapping inside cmd_update).
  ( cmd_update ) > /dev/null 2>&1 || true
  return 0
}

# ── Session spine (WS-0.3, P0.1) ──────────────────────────────────────────────
# Opens a real fos_session BEFORE exec'ing claude — lab-faithful (mirrors
# silken-runtime's own pre-exec session registration), but through the
# product's MCP tool surface (fos_session/fos_registry over the local mTLS
# proxy) instead of a local agent-runtime endpoint, which this product has
# none of.

# _resolve_device_id: stable device_id for this machine — analogous to
# ~/.fos/device.id in the lab. Created once (first run), reused thereafter.
_resolve_device_id() {
  local _id_file="${HOME}/.engram/device-id"
  if [ ! -f "${_id_file}" ]; then
    mkdir -p "$(dirname "${_id_file}")"
    if command -v uuidgen > /dev/null 2>&1; then
      uuidgen > "${_id_file}"
    elif [ -r /proc/sys/kernel/random/uuid ]; then
      cat /proc/sys/kernel/random/uuid > "${_id_file}"
    else
      # Last-resort fallback (no uuidgen, no /proc — e.g. some minimal
      # containers): not RFC4122, but stable across runs on THIS machine,
      # which is all device_id needs to be.
      echo "$(hostname)-$(date +%s)-$$" > "${_id_file}"
    fi
  fi
  cat "${_id_file}"
}

# _mcp_call: POST a JSON-RPC tools/call to the local mTLS proxy; prints the
# raw SSE "data:" payload line (prefix stripped), or nothing on any failure
# (network, auth, malformed response). Never trips errexit — `|| true` is
# unconditional on the pipeline regardless of which stage would otherwise
# fail. The proxy forwards EVERY local path to the single fixed upstream it's
# built for (mtls-proxy.ts: cfg.upstream, incoming path ignored) — /v1/mcp
# here is for readability/parity with the direct (non-proxied) curl pattern
# used elsewhere (ops/rls-scratch-test.sh), not a routing requirement.
_mcp_call() {
  local _tool="$1" _args_json="$2" _id="$3"
  curl -s --max-time 5 \
    -H "x-fos-key: ${FOS_API_KEY:-}" \
    -H "Content-Type: application/json" \
    -H "Accept: application/json, text/event-stream" \
    -d "{\"jsonrpc\":\"2.0\",\"id\":${_id},\"method\":\"tools/call\",\"params\":{\"name\":\"${_tool}\",\"arguments\":${_args_json}}}" \
    "http://127.0.0.1:${PROXY_PORT}/v1/mcp" 2>/dev/null \
    | grep "^data:" | head -1 | sed 's/^data: //' || true
}

# _mcp_result_field: extract one field from an MCP tool result. Two
# JSON.parse hops — the outer JSON-RPC envelope, then result.content[0].text
# (the tool's own JSON payload, per mcp.service.ts convention:
# content:[{type:'text', text:JSON.stringify(result)}]). Uses bun — already a
# hard dependency of this script (checked in _start_proxy) — no new
# dependency introduced. Prints nothing on any parse failure.
_mcp_result_field() {
  local _envelope="$1" _field="$2"
  [ -n "${_envelope}" ] || return 0
  bun -e '
    try {
      const envelope = JSON.parse(process.argv[1]);
      const inner = JSON.parse(envelope.result.content[0].text);
      const v = inner[process.argv[2]];
      if (v !== undefined && v !== null) console.log(v);
    } catch {}
  ' "${_envelope}" "${_field}" 2>/dev/null || true
}

# _open_session_spine: opens the fos_session for this launch and sets globals
# ENGRAM_SESSION_ID / ENGRAM_DEVICE_ID (read by cmd_open's final exec).
# $1 = project slug.
#
# BEST-EFFORT (deliberate divergence from silken-runtime, which hard-aborts
# on an empty session_id): this is the shipped client — a flaky network or a
# transient engram outage must not block the user from opening Claude at all.
# A missing ENGRAM_SESSION_ID just degrades /boot (no next_note surfaced) and
# /end-session (no real close — the watchdog reclaims the orphan) rather than
# refusing to start.
#
# NO auto-registration (WS-0.3.3 — REMOVED, F2.1). A prior version silently
# upserted the slug into the registry on the first slug_not_found here (dupla
# cobertura). That silently created a registry row for any typo'd/unknown slug
# on the user's behalf — the exact behavior the explicit slug-selection work
# (F2.2 picker) and explicit first-project bootstrap (F3.2, confirmed create)
# replace. Slug existence is now settled BEFORE this function runs (cmd_open
# resolves via arg / picker / confirmed bootstrap). If a slug still turns up
# unknown here, we DEGRADE (best-effort, no session) — we do NOT create it.
# This comment is a headstone, not an invitation: do not reintroduce the
# auto-upsert.
_open_session_spine() {
  local _slug="$1"
  ENGRAM_DEVICE_ID="$(_resolve_device_id)"
  ENGRAM_SESSION_ID=""

  if [ -z "${FOS_API_KEY:-}" ]; then
    _vecho "[hivemind] FOS_API_KEY ausente — sem sessão nesta janela (enrollment incompleto?)"
    return 0
  fi

  local _open_args _resp _err_field _session_id
  _open_args="{\"action\":\"open\",\"slug\":\"${_slug}\",\"mode\":\"manual-cli\",\"device_id\":\"${ENGRAM_DEVICE_ID}\",\"pid\":$$}"
  _resp="$(_mcp_call "fos_session" "${_open_args}" 1)"
  _err_field="$(_mcp_result_field "${_resp}" "_err")"

  # slug_not_found here is now a DEGRADE, not a trigger to auto-create (F2.1).
  # The slug was resolved/created explicitly upstream (arg / picker / bootstrap);
  # an unknown slug at this point means we simply open Claude with no session
  # spine rather than silently minting a registry row.
  if [ "${_err_field}" = "slug_not_found" ]; then
    _vecho "[hivemind] slug '${_slug}' desconhecido no registry — seguindo sem espinha de sessão (sem auto-registro)"
    return 0
  fi

  _session_id="$(_mcp_result_field "${_resp}" "session_id")"
  if [ -z "${_session_id}" ]; then
    _vecho "[hivemind] fos_session open não retornou session_id — seguindo sem espinha de sessão nesta janela"
    return 0
  fi

  ENGRAM_SESSION_ID="${_session_id}"
  _vecho "[hivemind] sessão aberta: ${ENGRAM_SESSION_ID} (slug=${_slug})"
}

# ── Slug selection (F2.2 / F3) ────────────────────────────────────────────────
# The registry is owner-scoped SERVER-SIDE (registry.service.ts: every read is
# `WHERE owner_id = <owner>`), so `fos_registry(action:list)` already returns
# ONLY this owner's slugs — the client never filters by owner and cannot see
# another's. Response envelope: {items:[{slug,name,status,...}], count}.

# _list_slugs: populate _SLUGS_RAW ("slug<TAB>name" lines, active only) for the
# current owner. Returns 0 on a VALID registry response — the list may be EMPTY
# (a genuine count:0 for an owner with no projects yet, the F3 bootstrap case).
# Returns 1 on transport/parse failure (no API key, proxy/network down,
# malformed payload). The caller MUST distinguish these two (F3.1): an EMPTY
# list means "bootstrap first project", an UNREACHABLE registry means "abort,
# don't guess" — collapsing them would silently offer to create a duplicate of
# an existing project during a network blip.
_list_slugs() {
  _SLUGS_RAW=""
  [ -n "${FOS_API_KEY:-}" ] || return 1
  local _resp
  _resp="$(_mcp_call "fos_registry" '{"action":"list"}' 1)"
  [ -n "${_resp}" ] || return 1
  local _out
  # bun exits 3 on parse failure / missing items array → the `||` maps that
  # (and any bun failure) to return 1. A valid empty array exits 0 with no
  # output → _SLUGS_RAW="" + return 0 (the count:0 bootstrap signal).
  _out="$(bun -e '
    try {
      const env = JSON.parse(process.argv[1]);
      const inner = JSON.parse(env.result.content[0].text);
      if (!inner || !Array.isArray(inner.items)) process.exit(3);
      for (const it of inner.items) {
        if (it.status && it.status !== "active") continue;
        if (!it.slug) continue;
        process.stdout.write(`${it.slug}\t${it.name || it.slug}\n`);
      }
    } catch { process.exit(3); }
  ' "${_resp}" 2>/dev/null)" || return 1
  _SLUGS_RAW="${_out}"
  return 0
}

# _pick_project — render this owner's slugs and set _PICKED_SLUG. Mirrors
# silken-runtime:_pick_project (fzf when available; numbered-read fallback;
# same color scheme + Ctrl-C/Ctrl-D → 130). Input: _SLUGS_RAW (from
# _list_slugs). NOTE (faithful adaptation, not a gap): silken-runtime also
# greys out slugs with a live session ON THIS DEVICE — that relies on the lab
# agent-runtime's /v1/sessions/active endpoint, which this product has no
# equivalent of, so that one sub-feature is intentionally omitted here.
_pick_project() {
  _PICKED_SLUG=""
  local -a slugs names
  local _s _n
  while IFS=$'\t' read -r _s _n; do
    [ -n "${_s}" ] || continue
    slugs+=("${_s}"); names+=("${_n:-$_s}")
  done <<< "${_SLUGS_RAW}"

  local n="${#slugs[@]}"
  if [ "${n}" -eq 0 ]; then
    return 1
  fi

  local C_HEAD C_NUM C_RSTL C_BLOCK
  if [ -t 1 ] && [ -z "${NO_COLOR:-}" ]; then
    C_HEAD=$'\033[1;36m'; C_NUM=$'\033[1;33m'; C_BLOCK=$'\033[2;31m'; C_RSTL=$'\033[0m'
  else
    C_HEAD=""; C_NUM=""; C_BLOCK=""; C_RSTL=""
  fi

  printf '%s┌─ HIVEMIND ─────────────────────────────────────┐%s\n' "$C_HEAD" "$C_RSTL" >&2
  printf '%s│  Selecione o projeto                           │%s\n' "$C_HEAD" "$C_RSTL" >&2
  printf '%s├────────────────────────────────────────────────┤%s\n' "$C_HEAD" "$C_RSTL" >&2
  local i
  for ((i=0; i<n; i++)); do
    printf '   %s%2d)%s  %s\n' "$C_NUM" "$((i+1))" "$C_RSTL" "${names[$i]}" >&2
  done
  printf '%s└────────────────────────────────────────────────┘%s\n' "$C_HEAD" "$C_RSTL" >&2

  if command -v fzf > /dev/null 2>&1; then
    local menu="" sel idx
    for ((i=0; i<n; i++)); do
      menu+="$((i+1))	${names[$i]}"$'\n'
    done
    sel=$(printf '%s' "$menu" | fzf --ansi --prompt='projeto> ' \
      --header='Enter seleciona · Esc/Ctrl-C cancela' \
      --with-nth=2.. --delimiter='\t') || return 130
    idx=$(printf '%s' "$sel" | cut -f1)
    [ -z "$idx" ] && return 130
    _PICKED_SLUG="${slugs[$((idx-1))]}"
  else
    local choice
    while :; do
      printf '%s  → número [1-%d] (Ctrl-C cancela): %s' "$C_NUM" "$n" "$C_RSTL" >&2
      if ! IFS= read -r choice; then
        echo "" >&2; return 130
      fi
      case "$choice" in
        ''|*[!0-9]*)
          printf '%s  ✗ Entrada inválida.%s\n' "$C_BLOCK" "$C_RSTL" >&2; continue ;;
      esac
      if [ "$choice" -lt 1 ] || [ "$choice" -gt "$n" ]; then
        printf '%s  ✗ Fora do intervalo.%s\n' "$C_BLOCK" "$C_RSTL" >&2; continue
      fi
      _PICKED_SLUG="${slugs[$((choice-1))]}"
      break
    done
  fi
  return 0
}

# _bootstrap_first_slug — owner has ZERO projects (F3.2). Creates the FIRST
# project EXPLICITLY: the name is always asked/confirmed from the human, NEVER
# derived from basename(cwd) or any other heuristic (decision 6e14806d, founder
# 2026-07-13 — the fos-web Project Hub is read-only, there is nothing to
# mirror; this is the first create surface, not a mirror). Sets _BOOTSTRAP_SLUG
# on success; leaves it empty + returns non-zero on decline/empty input.
# $1 = slug from an explicit `hivemind <slug>` arg ("" when none was given).
#
# ARCHITECTURAL NOTE (registered, not resolved here — Frente 2, out of scope):
# creating a slug is a MUTATION. This is currently the ONLY slug-create surface
# outside 4tuenyOS's agent-driven flow. If the Project Hub ever grows a create
# button, it MUST converge on this SAME fos_registry(action:upsert) call — not
# a second, divergent create path.
_bootstrap_first_slug() {
  local _arg_slug="${1:-}"
  _BOOTSTRAP_SLUG=""
  local _name _slug _reply

  echo "" >&2
  echo "Nenhum projeto encontrado para esta conta." >&2

  if [ -n "${_arg_slug}" ]; then
    # Name already came from the human (the explicit arg) — only confirm.
    printf 'Criar "%s" como seu primeiro projeto? [y/N] ' "${_arg_slug}" >&2
    IFS= read -r _reply || return 1
    case "${_reply}" in
      y|Y|yes|YES|s|S|sim|SIM)
        # code-review FIX 1: the arg was used VERBATIM as the slug — a
        # human-typed arg with spaces/symbols (e.g. `hivemind "Foo Bar"`)
        # produced a malformed, non-path/URL-safe slug ("Foo Bar"). Run the
        # SAME normalization as the no-arg path (:909) over the slug only —
        # `_name` stays the arg verbatim (what the human actually typed/
        # confirmed), only the SLUG is ASCII-folded/validated.
        _name="${_arg_slug}"
        _slug="$(printf '%s' "${_arg_slug}" | tr '[:upper:]' '[:lower:]' | tr -cs 'a-z0-9' '-' | sed -e 's/^-*//' -e 's/-*$//')"
        if [ -z "${_slug}" ]; then
          echo "Argumento não produz um slug válido (use letras/números) — nada criado." >&2
          return 1
        fi
        ;;
      *) echo "Cancelado — nada criado." >&2; return 1 ;;
    esac
  else
    # No arg — ask the name from scratch, WITHOUT pre-filling/suggesting.
    printf 'Como você quer chamar seu primeiro projeto? ' >&2
    IFS= read -r _name || return 1
    _name="$(printf '%s' "${_name}" | sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//')"
    if [ -z "${_name}" ]; then
      echo "Nome vazio — nada criado." >&2
      return 1
    fi
    # Derive a filesystem/URL-safe slug from the typed name (lowercase, runs of
    # non-alnum → single '-', trimmed). Mechanical normalization of the human's
    # own input — not a suggested default. Shown before create for transparency.
    _slug="$(printf '%s' "${_name}" | tr '[:upper:]' '[:lower:]' | tr -cs 'a-z0-9' '-' | sed -e 's/^-*//' -e 's/-*$//')"
    if [ -z "${_slug}" ]; then
      echo "Nome não produz um slug válido (use letras/números) — nada criado." >&2
      return 1
    fi
    printf 'Criando projeto "%s" (slug: %s)...\n' "${_name}" "${_slug}" >&2
  fi

  # Build the upsert args with bun so name/slug are JSON-escaped safely (a name
  # with a quote/backslash would otherwise corrupt hand-built JSON).
  local _dev _upsert_args
  _dev="$(_resolve_device_id)"
  _upsert_args="$(bun -e '
    const [slug, name, dev] = process.argv.slice(1);
    process.stdout.write(JSON.stringify({
      action: "upsert", slug, name,
      mode: "self-managed", kind: "product", status: "active",
      device_id: dev, registry_upsert_confirmation: true,
    }));
  ' "${_slug}" "${_name}" "${_dev}" 2>/dev/null)"
  if [ -z "${_upsert_args}" ]; then
    echo "Erro: falha ao montar a requisição de criação — nada criado." >&2
    return 1
  fi
  _mcp_call "fos_registry" "${_upsert_args}" 1 > /dev/null
  _BOOTSTRAP_SLUG="${_slug}"
  return 0
}

# cmd_open: start proxy + exec claude.
# $1 = slug (optional); remaining $@ passed to claude.
cmd_open() {
  local _slug="${1:-}"
  if [ $# -gt 0 ]; then shift; fi

  if ! _has_cert; then
    _setup_mode
  else
    _brand_header
  fi

  _maybe_auto_update
  _start_proxy

  # ── Resolve the project slug (F2.2 / F2.3 / F3) ──────────────────────────
  # The proxy is up now, so the owner-scoped registry is reachable for the
  # picker/bootstrap. Order: explicit arg > interactive selection/bootstrap.
  # There is deliberately NO basename(cwd) fallback (F2.3, founder-accepted
  # fail-closed): silently opening a wrong slug is worse than a clear abort.
  local _project_slug=""
  if [ -n "${_slug}" ]; then
    # Explicit arg — NEVER show the picker. If this owner has no projects yet,
    # offer to create THIS slug as the first one (F3.2, confirmed). Otherwise
    # open it as-is (an unknown slug just degrades the session spine; it is
    # never auto-created — F2.1).
    _project_slug="${_slug}"
    if [ -t 0 ] && [ -t 1 ] && _list_slugs && [ -z "${_SLUGS_RAW}" ]; then
      # code-review FIX 2: a declined/cancelled/invalid bootstrap here used to
      # be swallowed (`|| true`) and fall through to opening "${_project_slug}"
      # (the raw arg) anyway — the user said "don't create" and the
      # slug-ghost opened regardless (no registry row, degraded session).
      # Explicit decline now aborts explicitly, matching the no-arg bootstrap
      # path's behavior (:977-979) and decision 6e14806d's no-silent-creation
      # discipline. On CONFIRM, _BOOTSTRAP_SLUG is the slugified value (FIX 1)
      # — it may differ from the raw arg, so it replaces _project_slug.
      if _bootstrap_first_slug "${_project_slug}"; then
        _project_slug="${_BOOTSTRAP_SLUG}"
      else
        echo "Criação cancelada — nenhum projeto aberto." >&2
        exit 1
      fi
    fi
  elif [ -t 0 ] && [ -t 1 ]; then
    # No arg + interactive terminal: select an existing project, or bootstrap
    # the very first one.
    if _list_slugs; then
      if [ -z "${_SLUGS_RAW}" ]; then
        # count:0 — a genuine empty registry for this owner → bootstrap (F3.2).
        if _bootstrap_first_slug ""; then
          _project_slug="${_BOOTSTRAP_SLUG}"
        else
          echo "Nenhum projeto criado — encerrando." >&2
          exit 1
        fi
      else
        # count>0 — normal interactive selection (F3.1).
        local _rc=0
        _pick_project || _rc=$?
        if [ "${_rc}" -eq 130 ]; then
          echo "Seleção cancelada." >&2
          exit 130
        elif [ "${_rc}" -ne 0 ] || [ -z "${_PICKED_SLUG}" ]; then
          echo "Erro: falha ao selecionar o projeto." >&2
          exit 1
        fi
        _project_slug="${_PICKED_SLUG}"
      fi
    else
      # Registry UNREACHABLE — distinct from empty (F3.1). Do NOT guess or
      # bootstrap: creating during a network blip could duplicate an existing
      # project.
      echo "Erro: não foi possível consultar o registry (rede/proxy indisponível?) —" >&2
      echo "      não é seguro selecionar ou criar um projeto às cegas. Verifique 'hivemind status'." >&2
      exit 1
    fi
  else
    # No arg + non-interactive: fail closed (F2.3, founder-accepted). No
    # basename(cwd) fallback — automation must pass an explicit slug.
    echo "Erro: nenhum slug informado e a entrada não é um terminal interativo." >&2
    echo "      Rode 'hivemind <slug>' explicitamente em contexto não-interativo." >&2
    exit 1
  fi

  if [ -z "${_project_slug}" ]; then
    echo "Erro: nenhum projeto resolvido — encerrando." >&2
    exit 1
  fi

  # Espinha de sessão (WS-0.3) — abre DEPOIS do proxy responder no health,
  # ANTES do exec (silken-runtime mirror). Sets ENGRAM_SESSION_ID/
  # ENGRAM_DEVICE_ID (globals, best-effort — see _open_session_spine).
  _open_session_spine "${_project_slug}"

  # F0 auth fail-safe (item 5.0) — the isolated CONFIG_DIR may have no
  # credential at all (install.sh only seeds it best-effort from the user's
  # personal ~/.claude, and a brand-new CONFIG_DIR on a machine with no prior
  # personal login has nothing to seed from). Missing credential triggers a
  # login flow INSIDE the same isolated CONFIG_DIR, so the resulting auth
  # state stays apartada from the user's personal Claude Code account.
  # Confirmed live (G3, Claude Code CLI v2.1.207): `claude auth login`
  # authenticates-AND-EXITS (prints an OAuth URL, waits for the pasted
  # callback code, writes the credential, then returns) — it does NOT enter an
  # interactive session, so it is safe to run here and fall through to the
  # normal `exec claude` below afterwards. Fail-safe, not fail-closed: if the
  # login is skipped/cancelled/times out, we still proceed to `exec` (the
  # interactive session will show its own auth prompt if needed) — never abort
  # the whole command over auth. NOTE (P2, out of scope for this pass): this
  # only covers ABSENCE, not an EXPIRED-but-present credential — see
  # docs/wip/hivemind-runtime-refinement-and-provisioning.md item 5.0 OPEN.
  if [ ! -f "${HIVEMIND_HOME}/.claude/.credentials.json" ]; then
    echo ""
    echo "Nenhuma credencial encontrada no runtime isolado do HiveMind — fazendo login..."
    env CLAUDE_CONFIG_DIR="${HIVEMIND_HOME}/.claude" claude auth login || true
  fi

  # --setting-sources user (item 5.2, F2 isolation): the isolated CONFIG_DIR
  # already redirects commands/skills/MCP/global-CLAUDE.md (CLAUDE_CONFIG_DIR
  # above), but without this flag the user's PROJECT ./CLAUDE.md (walk-up from
  # cwd) still leaks into context — measured (P3/P4, CLI v2.1.207). This flag
  # is the scalpel that suppresses project-scoped settings/CLAUDE.md/.mcp.json
  # while keeping the product's user-scoped config intact — intentional, not
  # a side effect (re-measure if the embedded CLI version changes).
  exec env \
    CLAUDE_CONFIG_DIR="${HIVEMIND_HOME}/.claude" \
    ENGRAM_SLUG="${_project_slug}" \
    ENGRAM_SESSION_ID="${ENGRAM_SESSION_ID}" \
    ENGRAM_DEVICE_ID="${ENGRAM_DEVICE_ID}" \
    HIVEMIND_HOME="${HIVEMIND_HOME}" \
    claude --setting-sources user "$@"
}

# ── Entry point ───────────────────────────────────────────────────────────────

# Parse --verbose anywhere in argv; strip it before subcommand dispatch (it's
# a global flag, not a subcommand argument).
_VERBOSE=0
_ARGS=()
for _arg in "$@"; do
  case "${_arg}" in
    --verbose) _VERBOSE=1 ;;
    *) _ARGS+=("${_arg}") ;;
  esac
done
set -- "${_ARGS[@]+"${_ARGS[@]}"}"

case "${1:-}" in
  start)          shift || true; cmd_start ;;
  stop)           shift || true; cmd_stop ;;
  restart)        shift || true; cmd_restart ;;
  status)         shift || true; cmd_status ;;
  health)         shift || true; cmd_health ;;
  update)         shift || true; cmd_update ;;
  --version|-v)   cmd_version ;;
  --help|-h)      cmd_help ;;
  *)              cmd_open "$@" ;;
esac
