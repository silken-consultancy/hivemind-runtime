# HiveMind environment template.
# This file is written automatically by `hivemind` on first run (via the setup popup).
# Manual copy: cp env.template ~/.hivemind/.env  then fill in the values.

MTLS_CERT_PATH=~/.fos/mtls/<owner_id>.cert.pem
MTLS_KEY_PATH=~/.fos/mtls/<owner_id>.key.pem
MTLS_CA_PATH=~/.fos/mtls/ca.cert.pem
MTLS_UPSTREAM=https://kernel.silken.ia.br:4443/v1/mcp
MTLS_PROXY_PORT=7779
HIVEMIND_OWNER=<owner_id>
